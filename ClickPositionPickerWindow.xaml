<Window x:Class="GalgamePersonaStudio.ClickPositionPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择点击位置"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#40000000"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross"
        ResizeMode="NoResize">
    <Grid>
        <Border x:Name="CoordLabel" Background="#1E2F3D" CornerRadius="6" Padding="14,8"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderBrush="#3B82F6" BorderThickness="1">
            <TextBlock x:Name="CoordText" Foreground="#E2E8F0" FontSize="15" FontFamily="Consolas"
                       Text="点击游戏翻页位置（Enter 确认，Esc 取消）"/>
        </Border>
        <StackPanel x:Name="ButtonPanel" Orientation="Horizontal" HorizontalAlignment="Center"
                    VerticalAlignment="Bottom" Margin="0,0,0,30" Visibility="Collapsed">
            <Button x:Name="ConfirmBtn" Content="确认 (Enter)" Click="Confirm_Click"
                    Padding="20,8" FontSize="14" Cursor="Hand"
                    Background="#3B82F6" Foreground="White" BorderThickness="0"/>
            <Button Content="重新选择" Click="Reset_Click" Margin="10,0,0,0"
                    Padding="20,8" FontSize="14" Cursor="Hand"
                    Background="#FFFFFF" Foreground="#1A202C" BorderBrush="#CBD5E1" BorderThickness="1"/>
            <Button Content="取消 (Esc)" Click="Cancel_Click" Margin="10,0,0,0"
                    Padding="20,8" FontSize="14" Cursor="Hand"
                    Background="#FFFFFF" Foreground="#1A202C" BorderBrush="#CBD5E1" BorderThickness="1"/>
        </StackPanel>
    </Grid>
</Window>

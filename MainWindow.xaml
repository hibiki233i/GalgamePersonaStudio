<Window x:Class="GalgamePersonaStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Galgame Persona Studio"
        Width="1320"
        Height="860"
        MinWidth="1120"
        MinHeight="720"
        Background="#F0F4F8">
    <Window.Resources>
        <!-- Color Brushes -->
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F0F4F8"/>
        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#1E2F3D"/>
        <SolidColorBrush x:Key="SidebarForegroundBrush" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="SidebarMutedBrush" Color="#94A3B8"/>
        <SolidColorBrush x:Key="SidebarActiveBrush" Color="#3B82F6"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1A202C"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#718096"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#CBD5E1"/>

        <!-- Drop Shadow for dropdowns -->
        <DropShadowEffect x:Key="DropShadow" BlurRadius="10" Opacity="0.12" ShadowDepth="2" Direction="270"/>

        <!-- Card Border Style -->
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Section Heading -->
        <Style x:Key="SectionHeading" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1A202C"/>
        </Style>

        <!-- Section Subtitle -->
        <Style x:Key="SectionSubtitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#718096"/>
        </Style>

        <!-- Sidebar Nav Button -->
        <Style x:Key="SidebarNavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                Margin="8,2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D4A5E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Accent Button -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1A202C"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5F9"/>
                    <Setter Property="BorderBrush" Value="#94A3B8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern ComboBox Style -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#1A202C"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="7" SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="contentPresenter"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      IsHitTestVisible="False"
                                                      Margin="{TemplateBinding Padding}"
                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    <Path Grid.Column="1"
                                          Data="F1 M 0,0 L 8,0 L 4,5 Z"
                                          Fill="#718096"
                                          HorizontalAlignment="Right"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center"
                                          Stretch="None"/>
                                </Grid>
                            </Border>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent"
                                          Focusable="False"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border Background="#FFFFFF"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        Effect="{StaticResource DropShadow}">
                                    <ScrollViewer>
                                        <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="border" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern ComboBoxItem Style -->
        <Style x:Key="ModernComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1A202C"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="#1D4ED8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" x:Name="SidebarBorder" Width="260" Background="#1E2F3D">
            <Grid>
                <!-- Toggle button -->
                <Button x:Name="SidebarToggle"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,20,6,0"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand"
                        Click="ToggleSidebar_Click"
                        Width="24" Height="24">
                    <TextBlock x:Name="ToggleIcon" Text="◀" FontSize="11" Foreground="#94A3B8"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <!-- === Expanded View === -->
                <Grid x:Name="ExpandedSidebar">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- App Title -->
                    <StackPanel Margin="20,18,44,8">
                        <TextBlock Text="Galgame Persona Studio" FontSize="18" FontWeight="SemiBold" Foreground="#E2E8F0"/>
                        <TextBlock Text="角色人格提取工作台" FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                        <TextBlock x:Name="VersionText" Text="v1.0.0" FontSize="11" Foreground="#64748B" Margin="0,6,0,0" Cursor="Hand" MouseLeftButtonDown="VersionText_Click" ToolTip="点击打开项目主页"/>
                    </StackPanel>

                    <!-- Navigation -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                        <Button Style="{StaticResource SidebarNavButton}" Tag="persona" Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="◆" FontSize="12" Foreground="#3B82F6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="人格生成" Foreground="#E2E8F0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarNavButton}" Tag="character" Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="◆" FontSize="10" Foreground="#EC4899" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="角色管理" Foreground="#E2E8F0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarNavButton}" Tag="rag" Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="◆" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="RAG 检索" Foreground="#E2E8F0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarNavButton}" Tag="record" Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="◆" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="实时/自动记录" Foreground="#E2E8F0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarNavButton}" Tag="log" Click="SidebarNav_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="◆" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="日志" Foreground="#E2E8F0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- === Collapsed View === -->
                <StackPanel x:Name="CollapsedSidebar" Visibility="Collapsed" VerticalAlignment="Center">
                    <Button Style="{StaticResource SidebarNavButton}" Tag="persona" Click="SidebarNav_Click" Padding="16,10">
                        <TextBlock Text="◆" FontSize="16" Foreground="#3B82F6" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Style="{StaticResource SidebarNavButton}" Tag="character" Click="SidebarNav_Click" Padding="16,10">
                        <TextBlock Text="◆" FontSize="14" Foreground="#EC4899" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Style="{StaticResource SidebarNavButton}" Tag="rag" Click="SidebarNav_Click" Padding="16,10">
                        <TextBlock Text="◆" FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Style="{StaticResource SidebarNavButton}" Tag="record" Click="SidebarNav_Click" Padding="16,10">
                        <TextBlock Text="◆" FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Style="{StaticResource SidebarNavButton}" Tag="log" Click="SidebarNav_Click" Padding="16,10">
                        <TextBlock Text="◆" FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sidebar Resize Grip -->
        <Border Grid.Column="0" HorizontalAlignment="Right" Width="4" Background="#1E2F3D" Cursor="SizeWE"/>

        <!-- Content Area -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="20,18,20,18">
            <Grid>
                <!-- Persona Panel -->
                <StackPanel x:Name="PersonaPanel" Visibility="Visible">
                    <!-- Output Card -->
                    <Border Style="{StaticResource PanelBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="输出目录" Style="{StaticResource SectionSubtitle}"/>
                                <TextBox x:Name="OutputPathBox" Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="12,22,0,0">
                                <Button Content="选择目录" Click="ChooseOutputFolder_Click" Style="{StaticResource SecondaryButton}"/>
                                <CheckBox x:Name="ExportSoulCheck" Content="导出 SOUL.md" IsChecked="True" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- LLM Card -->
                    <Border Style="{StaticResource PanelBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="LLM" Style="{StaticResource SectionHeading}" Grid.ColumnSpan="3"/>
                            <StackPanel Grid.Row="1">
                                <TextBlock Text="人格提炼方式" Style="{StaticResource SectionSubtitle}"/>
                                <ComboBox x:Name="ProviderCombo" SelectionChanged="ProviderCombo_SelectionChanged" Style="{StaticResource ModernComboBox}" ItemContainerStyle="{StaticResource ModernComboBoxItem}">
                                    <ComboBoxItem Content="本地规则（不推荐）"/>
                                    <ComboBoxItem Content="Ollama / 开源本地模型"/>
                                    <ComboBoxItem Content="OpenAI-compatible API"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="最大证据行" Style="{StaticResource SectionSubtitle}"/>
                                <TextBox x:Name="MaxEvidenceBox" Text="180" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.ColumnSpan="3" x:Name="LlmEndpointPanel">
                                <TextBlock Text="Endpoint（完整 /v1/chat/completions 地址）" Style="{StaticResource SectionSubtitle}"/>
                                <TextBox x:Name="EndpointBox" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.ColumnSpan="3" x:Name="LlmApiPanel">
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Model" Style="{StaticResource SectionSubtitle}"/>
                                        <TextBox x:Name="ModelBox" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Text="API Key" Style="{StaticResource SectionSubtitle}"/>
                                        <DockPanel>
                                            <Button Content="显示" DockPanel.Dock="Right" PreviewMouseDown="ShowApiKey_MouseDown" PreviewMouseUp="HideApiKey_MouseUp" MouseLeave="HideApiKey_MouseUp" Style="{StaticResource SecondaryButton}" FontSize="11" Padding="8,4" Margin="8,0,0,0"/>
                                            <Grid>
                                                <PasswordBox x:Name="ApiKeyBox" MinHeight="30" Padding="8,4" Margin="0,4,0,8"/>
                                                <TextBox x:Name="ApiKeyRevealBox" Visibility="Collapsed" IsReadOnly="True" Margin="0,4,0,8"/>
                                            </Grid>
                                        </DockPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Embedding Card -->
                    <Border Style="{StaticResource PanelBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="嵌入 / RAG 前置" Style="{StaticResource SectionHeading}" Grid.ColumnSpan="3"/>
                            <StackPanel Grid.Row="1">
                                <TextBlock Text="嵌入方式" Style="{StaticResource SectionSubtitle}"/>
                                <ComboBox x:Name="EmbeddingModeCombo" SelectionChanged="EmbeddingModeCombo_SelectionChanged" Style="{StaticResource ModernComboBox}" ItemContainerStyle="{StaticResource ModernComboBoxItem}">
                                    <ComboBoxItem Content="不使用嵌入"/>
                                    <ComboBoxItem Content="本地哈希嵌入"/>
                                    <ComboBoxItem Content="OpenAI-compatible Embeddings"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="候选上限" Style="{StaticResource SectionSubtitle}"/>
                                <TextBox x:Name="EmbeddingCandidateBox" Text="800" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="12,0,0,0">
                                <TextBlock Text="批处理大小（0=自动）" Style="{StaticResource SectionSubtitle}"/>
                                <TextBox x:Name="EmbeddingBatchSizeBox" Text="0" Width="100" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.ColumnSpan="3" x:Name="EmbeddingApiPanel">
                                <TextBlock Text="Embed Endpoint（完整 /v1/embeddings 地址）" Style="{StaticResource SectionSubtitle}"/>
                                <TextBox x:Name="EmbeddingEndpointBox" Margin="0,4,0,0"/>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Embed Model" Style="{StaticResource SectionSubtitle}"/>
                                        <TextBox x:Name="EmbeddingModelBox" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Text="Embed API Key" Style="{StaticResource SectionSubtitle}"/>
                                        <DockPanel>
                                            <Button Content="显示" DockPanel.Dock="Right" PreviewMouseDown="ShowEmbeddingKey_MouseDown" PreviewMouseUp="HideEmbeddingKey_MouseUp" MouseLeave="HideEmbeddingKey_MouseUp" Style="{StaticResource SecondaryButton}" FontSize="11" Padding="8,4" Margin="8,0,0,0"/>
                                            <Grid>
                                                <PasswordBox x:Name="EmbeddingApiKeyBox" MinHeight="30" Padding="8,4" Margin="0,4,0,8"/>
                                                <TextBox x:Name="EmbeddingApiKeyRevealBox" Visibility="Collapsed" IsReadOnly="True" Margin="0,4,0,8"/>
                                            </Grid>
                                        </DockPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Button Content="生成人格文件" HorizontalAlignment="Right" Style="{StaticResource AccentButton}" Click="GeneratePersona_Click" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Character Panel -->
                <StackPanel x:Name="CharacterPanel" Visibility="Collapsed">
                    <Border Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <TextBlock Text="剧本与角色" Style="{StaticResource SectionHeading}"/>
                            <TextBlock Text="读取 GalTransl 风格 JSON，按频次筛选角色。" Style="{StaticResource SectionSubtitle}" Margin="0,4,0,12"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ScriptPathBox"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                                    <Button Content="选择文件" Click="ChooseScriptFile_Click" Style="{StaticResource SecondaryButton}"/>
                                    <Button Content="选择目录" Click="ChooseScriptFolder_Click" Style="{StaticResource SecondaryButton}" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Grid>

                            <DockPanel Margin="0,8,0,0">
                                <Button Content="扫描人物" Click="ScanCharacters_Click" Style="{StaticResource AccentButton}" DockPanel.Dock="Right"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="最低频次:" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource SectionSubtitle}"/>
                                    <TextBox x:Name="MinCountBox" Text="20" Width="70"/>
                                    <Button Content="应用筛选" Click="FilterCharacters_Click" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/>
                                </StackPanel>
                            </DockPanel>

                            <TextBlock Text="高频人物（可多选）" FontSize="14" FontWeight="SemiBold" Margin="0,20,0,8" Foreground="#1A202C"/>
                            <ListBox x:Name="CharacterList" SelectionMode="Multiple" MinHeight="360" MaxHeight="520"
                                     Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1"/>
                        </StackPanel>
                    </Border>

                    <!-- Example Filter Card -->
                    <Border Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <TextBlock Text="实例对话角色筛选（逗号分隔，仅在生成人格时优先选取与以下角色互动的对话）" Style="{StaticResource SectionSubtitle}"/>
                            <TextBox x:Name="ExampleCharFilterBox" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- RAG Panel -->
                <StackPanel x:Name="RagPanel" Visibility="Collapsed">
                    <Border Style="{StaticResource PanelBorder}">
                        <DockPanel>
                            <CheckBox x:Name="RagEnabledCheck" Content="启用 RAG 方向检索" VerticalAlignment="Center"/>
                            <CheckBox x:Name="FilterHSceneCheck" Content="过滤H场景对话（关键词）" VerticalAlignment="Center" Margin="20,0,0,0"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <TextBlock Text="RAG 证据行" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="RagTopKBox" Text="40" Width="80"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Border Style="{StaticResource PanelBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="预设方向（可多选）" Style="{StaticResource SectionSubtitle}" FontWeight="SemiBold"/>
                            <ListBox x:Name="RagPresetList" Grid.Row="1" SelectionMode="Multiple" Margin="0,8,0,0"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource PanelBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="自定义方向（一行一个）" Style="{StaticResource SectionSubtitle}" FontWeight="SemiBold"/>
                            <TextBox x:Name="RagCustomBox" Grid.Row="1" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Record Panel -->
                <StackPanel x:Name="RecordPanel" Visibility="Collapsed">
                    <Border Style="{StaticResource PanelBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="170"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="当前游戏进程" Style="{StaticResource SectionSubtitle}"/>
                                <TextBox x:Name="ProcessNameBox" Margin="0,4,0,0"/>
                                <TextBlock Text="窗口标题" Style="{StaticResource SectionSubtitle}" Margin="0,12,0,0"/>
                                <TextBox x:Name="WindowTitleBox" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="选择进程…" Click="ShowProcessPicker_Click" VerticalAlignment="Center" Style="{StaticResource SecondaryButton}"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource PanelBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="320"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="文本来源" Style="{StaticResource SectionSubtitle}"/>
                                <ComboBox x:Name="CaptureSourceCombo" MinWidth="300" SelectionChanged="CaptureSourceCombo_SelectionChanged" Style="{StaticResource ModernComboBox}" ItemContainerStyle="{StaticResource ModernComboBoxItem}" Margin="0,4,0,0">
                                    <ComboBoxItem Content="Clipboard / 外部剪贴板"/>
                                    <ComboBoxItem Content="OpenAI-compatible Vision"/>
                                    <ComboBoxItem Content="Umi-OCR 本地识别"/>
                                </ComboBox>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="采集间隔秒" Style="{StaticResource SectionSubtitle}" Margin="12,0,0,0"/>
                            <TextBox Grid.Column="1" x:Name="CaptureIntervalBox" Text="1.2" Width="100" Margin="12,24,0,8"/>
                            <TextBlock Grid.Column="2" Text="Clipboard 模式：监听剪贴板写 JSON（配合 LunaTranslator 外部进程）。OCR/Vision 模式：框选对话区域后自动截图识别。" Foreground="#718096" TextWrapping="Wrap" Margin="12,22,0,0" FontSize="12"/>
                        </Grid>
                    </Border>

                    <Border x:Name="OcrRegionPanel" Style="{StaticResource PanelBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock Text="对话区域 x,y,w,h" Style="{StaticResource SectionSubtitle}" VerticalAlignment="Center"/>
                                    <Button Content="框选" Click="PickDialogRegion_Click" Style="{StaticResource SecondaryButton}" FontSize="11" Padding="4,2" Margin="8,0,0,0" DockPanel.Dock="Right"/>
                                </DockPanel>
                                <TextBox x:Name="DialogRegionBox" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <DockPanel>
                                    <TextBlock Text="人名区域 x,y,w,h" Style="{StaticResource SectionSubtitle}" VerticalAlignment="Center"/>
                                    <Button Content="框选" Click="PickNameRegion_Click" Style="{StaticResource SecondaryButton}" FontSize="11" Padding="4,2" Margin="8,0,0,0" DockPanel.Dock="Right"/>
                                </DockPanel>
                                <TextBox x:Name="NameRegionBox" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border x:Name="VisionPanel" Style="{StaticResource PanelBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="260"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Vision Endpoint（完整 /v1/chat/completions 地址）" Style="{StaticResource SectionSubtitle}"/>
                                <TextBox x:Name="VisionEndpointBox" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Vision Model" Style="{StaticResource SectionSubtitle}"/>
                                <TextBox x:Name="VisionModelBox" Margin="0,4,0,0"/>
                                <TextBlock Text="Vision API Key" Style="{StaticResource SectionSubtitle}" Margin="0,12,0,0"/>
                                <DockPanel>
                                    <Button Content="显示" DockPanel.Dock="Right" PreviewMouseDown="ShowVisionKey_MouseDown" PreviewMouseUp="HideVisionKey_MouseUp" MouseLeave="HideVisionKey_MouseUp" Style="{StaticResource SecondaryButton}" FontSize="11" Padding="8,4" Margin="8,0,0,0"/>
                                    <Grid>
                                        <PasswordBox x:Name="VisionApiKeyBox" MinHeight="30" Padding="8,4" Margin="0,4,0,8"/>
                                        <TextBox x:Name="VisionApiKeyRevealBox" Visibility="Collapsed" IsReadOnly="True" Margin="0,4,0,8"/>
                                    </Grid>
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border x:Name="UmiOcrPanel" Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <TextBlock Text="Umi-OCR 本地 OCR（基于 PaddleOCR，支持中日文）" Foreground="#718096" FontSize="12" Margin="0,0,0,8"/>
                            <TextBlock Text="Umi-OCR API 地址" Style="{StaticResource SectionSubtitle}"/>
                            <TextBox x:Name="UmiOcrEndpointBox" Text="http://127.0.0.1:1224" Margin="0,4,0,0"/>
                            <TextBlock Text="在 Umi-OCR 的全局设置 → 高级中开启 HTTP 接口。保持默认端口 1224。" Foreground="#94A3B8" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Auto-Advance Card -->
                    <Border x:Name="AutoAdvancePanel" Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <CheckBox x:Name="AutoAdvanceCheck" Content="启用自动翻页（beta）" Checked="AutoAdvance_Changed" Unchecked="AutoAdvance_Changed"/>
                            <StackPanel x:Name="AutoAdvanceConfigPanel" Margin="0,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="翻页点击位置:" VerticalAlignment="Center"/>
                                    <TextBox x:Name="AdvanceClickBox" Grid.Column="1" Margin="8,0" IsReadOnly="True"/>
                                    <Button Grid.Column="2" Content="拾取位置" Click="PickAdvancePoint_Click" Style="{StaticResource SecondaryButton}"/>
                                </Grid>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="翻页后等待(秒):" VerticalAlignment="Center"/>
                                        <TextBox x:Name="PostClickDelayBox" Text="1.2" Width="60" Margin="6,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                                        <TextBlock Text="判定选择肢/卡死重试阈值:" VerticalAlignment="Center"/>
                                        <TextBox x:Name="StuckThresholdBox" Text="5" Width="50" Margin="6,0,0,0"/>
                                        <TextBlock Text="次" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Choice Detection Card -->
                    <Border x:Name="ChoicePanel" Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <CheckBox x:Name="ChoiceDetectionCheck" Content="启用选择肢检测" Checked="ChoiceDetection_Changed" Unchecked="ChoiceDetection_Changed"/>
                            <StackPanel x:Name="ChoiceConfigPanel" Margin="0,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="选择肢区域:" VerticalAlignment="Center"/>
                                    <TextBox x:Name="ChoiceRegionBox" Grid.Column="1" Margin="8,0"/>
                                    <Button Grid.Column="2" Content="框选" Click="PickChoiceRegion_Click" Style="{StaticResource SecondaryButton}" FontSize="11" Padding="8,4"/>
                                </Grid>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="选择肢处理:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="ChoiceModeCombo" SelectionChanged="ChoiceModeCombo_SelectionChanged" Grid.Column="1" Margin="8,0" Style="{StaticResource ModernComboBox}" ItemContainerStyle="{StaticResource ModernComboBoxItem}">
                                        <ComboBoxItem Content="弹窗手动选择"/>
                                        <ComboBoxItem Content="自动选择"/>
                                    </ComboBox>
                                </Grid>
                                <Grid x:Name="ChoiceAutoConfig" Margin="0,8,0,0" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="自动规则:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="ChoiceAutoRuleCombo" Grid.Column="1" Margin="8,0" Style="{StaticResource ModernComboBox}" ItemContainerStyle="{StaticResource ModernComboBoxItem}">
                                        <ComboBoxItem Content="选择第一个"/>
                                        <ComboBoxItem Content="选择最后一个"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Hotkey Card -->
                    <Border Style="{StaticResource PanelBorder}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="开始记录快捷键:" VerticalAlignment="Center"/>
                                <TextBox x:Name="StartHotkeyBox" Grid.Column="1" Margin="8,0" IsReadOnly="True"/>
                                <Button x:Name="SetStartHotkeyBtn" Grid.Column="2" Content="设置" Click="SetStartHotkey_Click" Style="{StaticResource SecondaryButton}" Padding="12,4"/>
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="停止记录快捷键:" VerticalAlignment="Center"/>
                                <TextBox x:Name="StopHotkeyBox" Grid.Column="1" Margin="8,0" IsReadOnly="True"/>
                                <Button x:Name="SetStopHotkeyBtn" Grid.Column="2" Content="设置" Click="SetStopHotkey_Click" Style="{StaticResource SecondaryButton}" Padding="12,4"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="记录输出目录" Style="{StaticResource SectionSubtitle}"/>
                                <TextBox x:Name="RecordOutputBox" Margin="0,4,0,0"/>
                                <CheckBox x:Name="OnlyNamedNowCheck" Content="立即只记录指定人名" Margin="0,12,0,0"/>
                                <TextBlock Text="累计到 N 条后只记录指定人名" Style="{StaticResource SectionSubtitle}"/>
                                <TextBox x:Name="OnlyAfterBox" Text="200" Width="100" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                                <TextBlock Text="指定人名，逗号分隔" Style="{StaticResource SectionSubtitle}" Margin="0,12,0,0"/>
                                <TextBox x:Name="AllowedNamesBox" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="12,20,0,0">
                                <Button Content="选择目录" Click="ChooseRecordOutput_Click" Style="{StaticResource SecondaryButton}"/>
                                <Button Content="测试一次" Click="CaptureOnce_Click" Style="{StaticResource SecondaryButton}" Margin="0,6,0,0"/>
                                <Button x:Name="StartCaptureBtn" Content="开始记录" FontWeight="SemiBold" Click="StartCapture_Click" Style="{StaticResource AccentButton}" Margin="0,6,0,0"/>
                                <Button x:Name="StopCaptureBtn" Content="停止" Click="StopCapture_Click" Style="{StaticResource SecondaryButton}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Log Panel -->
                <StackPanel x:Name="LogPanel" Visibility="Collapsed">
                    <TextBox x:Name="LogBox"
                             FontFamily="Cascadia Mono"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             IsReadOnly="True"
                             Background="#1A202C"
                             Foreground="#E2E8F0"
                             BorderBrush="#2D3748"
                             BorderThickness="1"
                             MinHeight="640"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Toast Notification -->
        <Border x:Name="ToastBorder" Grid.ColumnSpan="2"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,16,0,0" Padding="20,12"
                CornerRadius="8" BorderThickness="1"
                Opacity="0" Visibility="Collapsed"
                IsHitTestVisible="False">
            <TextBlock x:Name="ToastText" FontSize="14" FontWeight="SemiBold"
                       TextWrapping="Wrap" MaxWidth="480" TextAlignment="Center"/>
        </Border>
    </Grid>
</Window>

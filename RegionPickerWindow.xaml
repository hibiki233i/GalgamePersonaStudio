<Window x:Class="GalgamePersonaStudio.RegionPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="框选区域"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#40000000"
        WindowState="Maximized"
        Topmost="False"
        ShowInTaskbar="False"
        Cursor="Cross"
        ResizeMode="NoResize">
    <Grid>
        <Image x:Name="ScreenImage" Stretch="None" HorizontalAlignment="Left" VerticalAlignment="Top" Visibility="Collapsed"/>
        <Canvas x:Name="OverlayCanvas" Visibility="Collapsed">
            <Rectangle x:Name="SelectionRect" Stroke="#3B82F6" StrokeThickness="2" Fill="#203B82F6" Visibility="Collapsed"/>
        </Canvas>
        <Border x:Name="CoordLabel" Background="#1E2F3D" CornerRadius="6" Padding="10,6"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderBrush="#3B82F6" BorderThickness="1">
            <TextBlock x:Name="CoordText" Foreground="#E2E8F0" FontSize="16" FontFamily="Consolas"
                       Text="已隐藏主窗口。&#x0a;Ctrl+Shift+R 截图框选&#x0a;Ctrl+Shift+C 取消"/>
        </Border>
        <StackPanel x:Name="ButtonPanel" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20" Visibility="Collapsed">
            <Button x:Name="ConfirmBtn" Content="确认 (Enter)" Click="Confirm_Click"
                    Padding="20,8" FontSize="14" Cursor="Hand"
                    Background="#3B82F6" Foreground="White" BorderThickness="0"/>
            <Button Content="取消 (Esc)" Click="Cancel_Click" Margin="10,0,0,0"
                    Padding="20,8" FontSize="14" Cursor="Hand"
                    Background="#FFFFFF" Foreground="#1A202C" BorderBrush="#CBD5E1" BorderThickness="1"/>
        </StackPanel>
    </Grid>
</Window>
